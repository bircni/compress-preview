{
  "name": "zip-preview",
  "displayName": "Zip Preview",
  "description": "VS Code extension: preview zip file contents when opening .zip files",
  "publisher": "bircni",
  "version": "0.0.1",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bircni/zip-preview"
  },
  "homepage": "https://github.com/bircni/zip-preview",
  "bugs": {
    "url": "https://github.com/bircni/zip-preview/issues"
  },
  "keywords": [
    "zip",
    "preview",
    "archive",
    "vscode",
    "unzip",
    "viewer",
    "files"
  ],
  "categories": [
    "Other",
    "Visualization"
  ],
  "galleryBanner": {
    "color": "#0f3d99",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "main": "dist/extension.js",
  "scripts": {
    "audit": "npm audit --audit-level high",
    "build": "npm run compile && npm run bundle && npm run copy:webview && npm run package",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js --sourcemap",
    "check-unused": "depcheck .",
    "clean": "rimraf dist",
    "compile": "tsc --project tsconfig.build.json",
    "copy:webview": "mkdir -p dist/webview && cp src/webview/content.html dist/webview/content.html",
    "format": "prettier --check \"src/**/*.ts\" \"*.json\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"*.json\"",
    "install:debug": "npm run build && code --install-extension dist/extension.vsix --force",
    "uninstall:debug": "code --uninstall-extension zip-preview.zip-preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "vsce package --out dist/extension.vsix",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "test:report": "jest && echo 'HTML report at: .tmp/coverage/lcov-report/index.html'",
    "test:watch": "jest --watch",
    "validate": "npm run check-unused && npm run lint && npm run format && npm run test:coverage && npm run build",
    "watch": "tsc --project tsconfig.build.json --watch"
  },
  "dependencies": {
    "yauzl": "3.2.1"
  },
  "overrides": {
    "yauzl": "3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node-lts": "24.0.0",
    "@types/archiver": "7.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@types/vscode": "1.105.0",
    "@types/yauzl": "2.10.3",
    "@vscode/vsce": "3.7.1",
    "archiver": "7.0.1",
    "depcheck": "1.4.7",
    "esbuild": "0.27.4",
    "eslint": "10.0.3",
    "jest": "30.3.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  },
  "activationEvents": [
    "onCustomEditor:zipPreview"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "zipPreview",
        "displayName": "Zip Preview",
        "selector": [
          {
            "filenamePattern": "*.zip"
          }
        ]
      }
    ]
  }
}
