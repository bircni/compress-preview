{
  "name": "compress-preview",
  "displayName": "Compress Preview",
  "description": "VS Code extension: preview ZIP, TAR, and GZIP archive contents directly in the editor",
  "publisher": "bircni",
  "version": "0.3.0",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bircni/compress-preview"
  },
  "homepage": "https://github.com/bircni/compress-preview",
  "bugs": {
    "url": "https://github.com/bircni/compress-preview/issues"
  },
  "keywords": [
    "zip",
    "tar",
    "tgz",
    "gzip",
    "gz",
    "jar",
    "apk",
    "vsix",
    "xpi",
    "preview",
    "archive",
    "vscode",
    "unzip",
    "viewer",
    "files"
  ],
  "categories": [
    "Other",
    "Visualization"
  ],
  "galleryBanner": {
    "color": "#0f3d99",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "main": "dist/extension.js",
  "scripts": {
    "audit": "npm audit --audit-level high",
    "build": "npm run compile && npm run bundle && npm run copy:webview && npm run package",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js --sourcemap",
    "check:fixtures": "tsx scripts/check-fixtures.ts",
    "check-unused": "depcheck .",
    "clean": "rimraf dist",
    "compile": "tsc --project tsconfig.build.json",
    "copy:webview": "tsx scripts/copy-webview.ts",
    "format": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\" \"eslint.config.ts\" \"vitest.config.ts\" \"*.json\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"eslint.config.ts\" \"vitest.config.ts\" \"*.json\"",
    "generate:fixtures": "tsx scripts/generate-fixtures.ts",
    "install:code:debug": "npm run build && code --install-extension dist/extension.vsix --force",
    "uninstall:code:debug": "code --uninstall-extension bircni.compress-preview",
    "install:cursor:debug": "npm run build && cursor --install-extension dist/extension.vsix --force",
    "uninstall:cursor:debug": "cursor --uninstall-extension bircni.compress-preview",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "package": "vsce package --out dist/extension.vsix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run bundle && npm run copy:webview && tsx scripts/run-e2e.ts",
    "test:report": "vitest run --coverage && echo 'HTML report at: .tmp/coverage/lcov-report/index.html'",
    "test:watch": "vitest",
    "release": "tsx scripts/release.ts",
    "coverage:summary": "tsx scripts/write-coverage-summary.ts",
    "validate": "npm run check-unused && npm run lint && npm run format && npm run check:fixtures && npm run test:coverage && npm run test:e2e && npm run build && npm run audit",
    "watch": "tsc --project tsconfig.build.json --watch"
  },
  "dependencies": {
    "tar-stream": "3.2.0",
    "yauzl": "3.3.0"
  },
  "overrides": {
    "diff": "8.0.4",
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node-lts": "24.0.0",
    "@types/archiver": "7.0.0",
    "@types/node": "25.8.0",
    "@types/tar-stream": "3.1.4",
    "@types/vscode": "1.105.0",
    "@types/yauzl": "2.10.3",
    "@types/yazl": "3.3.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.1",
    "archiver": "8.0.0",
    "depcheck": "1.4.7",
    "esbuild": "0.28.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "mocha": "11.7.5",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "^4.1.6",
    "yazl": "3.3.1"
  },
  "activationEvents": [
    "onCustomEditor:compressPreview"
  ],
  "contributes": {
    "configuration": {
      "title": "Compress Preview",
      "properties": {
        "compress-preview.listTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 300000,
          "markdownDescription": "Maximum time in milliseconds to spend building the archive entry list before returning partial results. Increase for very large archives on slow disks."
        },
        "compress-preview.watchArchiveFile": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "When enabled, the preview reloads automatically when the archive file changes on disk."
        },
        "compress-preview.tempPreviewMaxAgeDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 365,
          "markdownDescription": "Remove cached binary preview folders under the OS temp directory after this many days without use."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "compressPreview",
        "displayName": "Compress Preview",
        "selector": [
          {
            "filenamePattern": "*.zip"
          },
          {
            "filenamePattern": "*.jar"
          },
          {
            "filenamePattern": "*.apk"
          },
          {
            "filenamePattern": "*.vsix"
          },
          {
            "filenamePattern": "*.xpi"
          },
          {
            "filenamePattern": "*.whl"
          },
          {
            "filenamePattern": "*.war"
          },
          {
            "filenamePattern": "*.ear"
          },
          {
            "filenamePattern": "*.tar"
          },
          {
            "filenamePattern": "*.tgz"
          },
          {
            "filenamePattern": "*.tar.gz"
          },
          {
            "filenamePattern": "*.gz"
          }
        ]
      }
    ]
  }
}
