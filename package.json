{
  "name": "compress-preview",
  "displayName": "Compress Preview",
  "description": "VS Code extension: preview ZIP, TAR, and GZIP archive contents directly in the editor",
  "publisher": "bircni",
  "version": "0.1.0",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bircni/compress-preview"
  },
  "homepage": "https://github.com/bircni/compress-preview",
  "bugs": {
    "url": "https://github.com/bircni/compress-preview/issues"
  },
  "keywords": [
    "zip",
    "tar",
    "tgz",
    "gzip",
    "gz",
    "jar",
    "apk",
    "vsix",
    "xpi",
    "preview",
    "archive",
    "vscode",
    "unzip",
    "viewer",
    "files"
  ],
  "categories": [
    "Other",
    "Visualization"
  ],
  "galleryBanner": {
    "color": "#0f3d99",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "main": "dist/extension.js",
  "scripts": {
    "audit": "npm audit --audit-level high",
    "build": "npm run compile && npm run bundle && npm run copy:webview && npm run package",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js --sourcemap",
    "check:fixtures": "node scripts/check-fixtures.js",
    "check-unused": "depcheck .",
    "clean": "rimraf dist",
    "compile": "tsc --project tsconfig.build.json",
    "copy:webview": "node scripts/copy-webview.js",
    "format": "prettier --check \"src/**/*.ts\" \"*.json\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"*.json\"",
    "generate:fixtures": "node scripts/generate-fixtures.js",
    "install:code:debug": "npm run build && code --install-extension dist/extension.vsix --force",
    "uninstall:code:debug": "code --uninstall-extension bircni.compress-preview",
    "install:cursor:debug": "npm run build && cursor --install-extension dist/extension.vsix --force",
    "uninstall:cursor:debug": "cursor --uninstall-extension bircni.compress-preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "vsce package --out dist/extension.vsix",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "test:e2e": "npm run bundle && npm run copy:webview && node scripts/run-e2e.js",
    "test:report": "jest && echo 'HTML report at: .tmp/coverage/lcov-report/index.html'",
    "test:watch": "jest --watch",
    "release": "node scripts/release.js",
    "validate": "npm run check-unused && npm run lint && npm run format && npm run check:fixtures && npm run test:coverage && npm run test:e2e && npm run build && npm run audit",
    "watch": "tsc --project tsconfig.build.json --watch"
  },
  "dependencies": {
    "tar-stream": "^3.1.7",
    "yauzl": "3.2.1"
  },
  "overrides": {
    "yauzl": "3.2.1",
    "diff": "8.0.2",
    "serialize-javascript": "7.0.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node-lts": "24.0.0",
    "@types/archiver": "7.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@types/tar-stream": "^3.1.4",
    "@types/vscode": "1.105.0",
    "@types/yauzl": "2.10.3",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "3.7.1",
    "archiver": "7.0.1",
    "depcheck": "1.4.7",
    "esbuild": "0.27.4",
    "eslint": "10.0.3",
    "jest": "30.3.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "mocha": "^11.7.1",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "yazl": "^3.3.1"
  },
  "activationEvents": [
    "onCustomEditor:compressPreview"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "compressPreview",
        "displayName": "Compress Preview",
        "selector": [
          {
            "filenamePattern": "*.zip"
          },
          {
            "filenamePattern": "*.jar"
          },
          {
            "filenamePattern": "*.apk"
          },
          {
            "filenamePattern": "*.vsix"
          },
          {
            "filenamePattern": "*.xpi"
          },
          {
            "filenamePattern": "*.whl"
          },
          {
            "filenamePattern": "*.war"
          },
          {
            "filenamePattern": "*.ear"
          },
          {
            "filenamePattern": "*.tar"
          },
          {
            "filenamePattern": "*.tgz"
          },
          {
            "filenamePattern": "*.tar.gz"
          },
          {
            "filenamePattern": "*.gz"
          }
        ]
      }
    ]
  }
}
